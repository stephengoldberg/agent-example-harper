{
  "name": "agent-example-harper",
  "version": "1.0.0",
  "description": "A conversational AI agent with persistent memory, built on Harper and Claude",
  "type": "module",
  "engines": {
    "harperdb": "^4.4"
  },
  "scripts": {
    "setup": "node scripts/download-model.js",
    "predev": "node scripts/download-model.js",
    "prestart": "node scripts/download-model.js",
    "start": "npx -y dotenv-cli -e .env -o -- harperdb run .",
    "dev": "npx -y dotenv-cli -e .env -o -- harperdb dev .",
    "deploy": "npx -y dotenv-cli -- harperdb deploy . restart=rolling replicated=true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "graphql": "^16.8.1",
    "harper-fabric-embeddings": "^0.2.2"
  },
  "optionalDependencies": {
    "@node-llama-cpp/mac-arm64-metal": "3.17.1",
    "@node-llama-cpp/mac-x64": "3.17.1",
    "@node-llama-cpp/linux-x64": "3.17.1"
  }
}
